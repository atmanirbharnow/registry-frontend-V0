rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection
    match /users/{userId} {
      // Anyone can read user profiles (needed for admin panel user list)
      allow read: if request.auth != null;

      // Users can create/update their own profile
      allow create, update: if request.auth != null && request.auth.uid == userId;

      // Admins can update ANY user's profile (needed for role management)
      allow update: if request.auth != null
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Actions collection
    match /actions/{actionId} {
      // Anyone authenticated can read actions
      allow read: if request.auth != null;

      // Users can create their own actions
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      // Users can update/delete their own actions
      allow update, delete: if request.auth != null
                            && resource.data.userId == request.auth.uid;

      // Admins can update/delete any action
      allow update, delete: if request.auth != null
                            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Institutions collection
    match /institutions/{institutionId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      allow update, delete: if request.auth != null
                            && resource.data.userId == request.auth.uid;

      // Admins can manage any institution
      allow update, delete: if request.auth != null
                            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Meta collection (registry counter, etc.)
    match /meta/{docId} {
      allow read: if request.auth != null;
      // Counter updates happen via server-side payment verification API
      // Any authenticated user can write (server controls when this is called)
      allow write: if request.auth != null;
    }
  }
}
